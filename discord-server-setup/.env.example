# Discord bot token (Bot tab in https://discord.com/developers/applications)
BOT_TOKEN=

# ID of the server you manually created and invited the bot to (with Administrator perms)
# Enable Developer Mode in Discord settings, then right-click the server icon -> Copy Server ID
GUILD_ID=

# The bot's application ID, needed to register slash commands (run `node get-client-id.js` to find it)
CLIENT_ID=

# Set to "true" to delete every existing role/channel (except @everyone) before building the new layout.
# Leave "false" on the first dry run if you want to eyeball the plan first.
WIPE_EXISTING=false
